                </tr>
                <tr class="border-bottom border-light border-opacity-10">
                    <td class="ps-4 py-3 fw-bold neon-text-cyan">ASP.NET Core MVC</td>
                    <td class="py-3 opacity-75">Enrutamiento y Motor de Vistas (Razor)</td>
                    <td class="pe-4 py-3 text-end"><span class="badge border border-info text-info">8.0</span></td>
                </tr>
                <tr class="border-bottom border-light border-opacity-10">
                    <td class="ps-4 py-3 fw-bold neon-text-yellow">Microsoft SignalR</td>
                    <td class="py-3 opacity-75">Comunicación bi-direccional en tiempo real vía WebSockets</td>
                    <td class="pe-4 py-3 text-end"><span class="badge border border-warning text-warning">8.0.0</span></td>
                </tr>
                <tr class="border-bottom border-light border-opacity-10">
                    <td class="ps-4 py-3 fw-bold text-light">Bootstrap</td>
                    <td class="py-3 opacity-75">Sistema de diseño responsivo CSS/JS</td>
                    <td class="pe-4 py-3 text-end"><span class="badge border border-secondary text-light">5.3.2</span></td>
                </tr>
                <tr class="border-bottom border-light border-opacity-10">
                    <td class="ps-4 py-3 fw-bold text-light">JavaScript</td>
