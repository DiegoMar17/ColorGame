    <div class="text-center mt-4">
        <a href="@Url.Action("Index", "Home")" class="btn btn-neon-cyan btn-lg px-5 py-3 rounded-pill shadow-sm fw-bold tracking-wide">➔ VOLVER AL JUEGO</a>
    </div>
</div>
